    "@web3auth/auth": "^11.4.2",
    "@web3auth/modal": "file:../../packages/modal",
    "@web3auth/no-modal": "file:../../packages/no-modal",
    "@web3auth/sign-in-with-web3": "^6.1.0",
    "@web3auth/ws-embed": "file:../../web3auth-ws-embed-5.6.5.tgz",
