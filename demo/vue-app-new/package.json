{
  "name": "vue-app-new",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "dev": "vite",
    "serve": "vite preview",
    "build": "npm run type-check && vite build",
    "lint": "eslint --ext .js,.vue,.ts --ignore-path .gitignore --fix src"
  },
  "dependencies": {
    "@solana-program/system": "^0.12.0",
    "@solana/kit": "^6.8.0",
    "@tanstack/vue-query": "^5.100.5",
    "@toruslabs/base-controllers": "^9.8.0",
    "@toruslabs/ethereum-controllers": "^9.8.0",
    "@toruslabs/solana-controllers": "^9.8.0",
    "@toruslabs/vue-components": "^9.0.1",
    "@toruslabs/vue-icons": "^9.0.0",
    "@wagmi/vue": "^0.5.6",
    "@web3auth/auth": "^11.8.0",
    "@web3auth/modal": "file:../../packages/modal",
    "@web3auth/no-modal": "file:../../packages/no-modal",
    "@web3auth/sign-in-with-web3": "^6.1.0",
    "@web3auth/ws-embed": "^6.0.0",
    "ethers": "^6.16.0",
    "ox": "^0.14.20",
    "petite-vue-i18n": "^11.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vue": "^3.5.33"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "use-sync-external-store": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@toruslabs/eslint-config-vue": "^5.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.0"
  },
  "lint-staged": {
    "!(*d).{js,ts}": [
