{
  "name": "vue-app-new",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "analyze": "source-map-explorer dist/assets/*.js dist/assets/*.map --no-border-checks",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "dev": "vite",
    "serve": "vite preview",
    "build": "npm run type-check && vite build",
    "lint": "eslint --ext .js,.vue,.ts --ignore-path .gitignore --fix src"
  },
  "dependencies": {
    "@solana-program/system": "^0.12.2",
    "@solana/kit": "^6.9.0",
    "@tanstack/vue-query": "^5.100.14",
    "@toruslabs/base-controllers": "^9.10.0",
    "@toruslabs/ethereum-controllers": "^9.11.0",
    "@toruslabs/solana-controllers": "^9.11.0",
    "@toruslabs/vue-components": "^9.0.1",
    "@toruslabs/vue-icons": "^9.0.0",
    "@wagmi/vue": "^0.5.17",
    "@web3auth/auth": "^11.8.1",
    "@web3auth/modal": "file:../../packages/modal",
    "@web3auth/no-modal": "file:../../packages/no-modal",
    "@web3auth/sign-in-with-web3": "^6.1.0",
    "@web3auth/ws-embed": "^6.1.0",
    "viem": "^2.52.0",
    "ox": "^0.14.27",
    "petite-vue-i18n": "^11.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vue": "^3.5.35"
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "use-sync-external-store": "^1.4.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@toruslabs/eslint-config-vue": "^5.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "8.0.16",
    "vue-tsc": "^3.3.3"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.0"
  },
  "lint-staged": {
    "!(*d).{js,ts}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{json, md}": [
      "prettier --write"
    ]
  }
}
