# EVM wallet address that receives payments (Base Sepolia testnet)
EVM_ADDRESS=0xYourWalletAddressHere

# Solana wallet address that receives payments (devnet by default)
SVM_ADDRESS=YourSolanaWalletAddressHere

# x402 facilitator endpoint (defaults to the public Coinbase facilitator)
FACILITATOR_URL=https://x402.org/facilitator

# EVM network CAIP-2 identifier (defaults to Base Sepolia)
EVM_NETWORK=eip155:84532

# Solana network CAIP-2 identifier (defaults to devnet)
# Options: solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1 (devnet)
#          solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp (mainnet)
SVM_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# Port to listen on (defaults to 4021 — matches the wagmi demo app)
PORT=4021
